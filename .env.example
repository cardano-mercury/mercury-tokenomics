# Drizzle / shared Postgres (the same database the other Mercury apps use)
DATABASE_URL="postgres://root:mysecretpassword@localhost:5544/local"

ORIGIN="http://localhost:5173"

# Better Auth. For production use 32+ characters generated with high entropy.
# This MUST be identical across all Mercury apps so sessions are shared (SSO).
# https://www.better-auth.com/docs/installation
BETTER_AUTH_SECRET=""

# Parent domain for cross-subdomain SSO cookies in production, e.g. .cardano-mercury.com.
# Leave blank for local development (localhost cookies are shared across ports).
COOKIE_DOMAIN=""
