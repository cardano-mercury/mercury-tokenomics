# Drizzle / shared Postgres (the same database the other Mercury apps use).
# Tokenomics creates only its own tokenomics_* tables; the shared auth tables are owned by
# mercury-core and must already exist, since tokenomics_project.owner_id foreign-keys to "user".
DATABASE_URL="postgres://root:mysecretpassword@localhost:5544/local"

# The app's own public URL. In production this is the https origin Caddy serves,
# e.g. https://demo-tokenomics.cardano-mercury.com
ORIGIN="http://localhost:5173"

# Port the built app binds to (adapter-node), unset defaults to 3000.
# In Docker each app has its own container, so both can sit on 3000 and the Dockerfile sets it.
# Only set this explicitly when running both apps as bare Node processes on one machine, where
# mercury-financials would otherwise claim 3000 first.
PORT="3001"

# Better Auth. For production use 32+ characters generated with high entropy
# (openssl rand -base64 32). This MUST be byte-for-byte identical across all Mercury apps: a
# session minted by one app is rejected by the other, with no useful error, if it differs.
# https://www.better-auth.com/docs/installation
BETTER_AUTH_SECRET=""

# Parent domain for cross-subdomain SSO cookies in production, e.g. .cardano-mercury.com.
# Leave blank for local development (localhost cookies are shared across ports).
COOKIE_DOMAIN=""

# Mail transport for magic-link sign-in, e.g. smtp://user:pass@host:587 (the deploy stack points
# this at a mailpit sink for its local dry run). Set it and magic links are sent over SMTP.
#
# Left blank, magic link is offered only in development, where the link is printed to the server
# console. Left blank in production the option is hidden entirely, rather than advertising a sign-in
# whose link is written to the container's stdout and never reaches anyone. Email and password (and
# TOTP two-factor) work regardless.
SMTP_URL=""

# Sender address for outgoing mail. Defaults to Mercury Tokenomics <no-reply@cardano-mercury.com>.
MAIL_FROM=""

# Behind a TLS-terminating reverse proxy (Caddy in the production stack), adapter-node has to be
# told which headers carry the real protocol and host. Without them it builds absolute URLs from
# the internal address (http://tokenomics:3000) and Better Auth rejects its own callbacks as
# cross-origin. The Dockerfile already bakes these in; set them by hand only when running the
# built server behind a proxy without that image.
PROTOCOL_HEADER="x-forwarded-proto"
HOST_HEADER="x-forwarded-host"
