# Matches .prettierrc.json exactly. It has to: an editor or an agent that reads this file but has not
# loaded Prettier will indent one way, Prettier will reformat the other way, and every save fights.
# If you change one of these files, change the other.
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# Prettier reads this file, so these values must match .prettierrc.json or they silently override it.
# indent_size maps to Prettier's tabWidth: setting it to 4 here reformats the whole repo.
# Prettier: "useTabs": true, "tabWidth": 2, "printWidth": 100
indent_style = tab
indent_size = 2
max_line_length = 100

# Prettier hard-wraps nothing in markdown by default, and trailing whitespace is a line break in it.
[*.md]
trim_trailing_whitespace = false

# YAML cannot be indented with tabs. The spec forbids it.
[*.{yml,yaml}]
indent_style = space
indent_size = 2

[*.json]
indent_style = tab
